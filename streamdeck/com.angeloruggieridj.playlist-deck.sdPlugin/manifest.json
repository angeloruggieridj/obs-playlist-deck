{
  "SDKVersion": 2,
  "Version": "1.0.0",
  "Author": "Angelo Ruggieri",
  "Name": "Playlist Deck",
  "Description": "Control the OBS Playlist Deck plugin (next, previous, play/pause, stop, play item) over obs-websocket.",
  "Category": "Playlist Deck",
  "CategoryIcon": "icons/category",
  "Icon": "icons/category",
  "URL": "https://github.com/angeloruggieridj/obs-playlist-deck",
  "CodePath": "app.html",
  "PropertyInspectorPath": "pi/inspector.html",
  "Software": { "MinimumVersion": "6.0" },
  "OS": [
    { "Platform": "mac", "MinimumVersion": "10.15" },
    { "Platform": "windows", "MinimumVersion": "10" }
  ],
  "Actions": [
    {
      "UUID": "com.angeloruggieridj.playlist-deck.next",
      "Name": "Next",
      "Tooltip": "Play the next item",
      "Icon": "icons/next",
      "States": [{ "Image": "icons/next", "TitleAlignment": "bottom" }]
    },
    {
      "UUID": "com.angeloruggieridj.playlist-deck.previous",
      "Name": "Previous",
      "Tooltip": "Play the previous item",
      "Icon": "icons/prev",
      "States": [{ "Image": "icons/prev", "TitleAlignment": "bottom" }]
    },
    {
      "UUID": "com.angeloruggieridj.playlist-deck.playpause",
      "Name": "Play / Pause",
      "Tooltip": "Toggle play/pause of the bound source",
      "Icon": "icons/playpause",
      "States": [{ "Image": "icons/playpause", "TitleAlignment": "bottom" }]
    },
    {
      "UUID": "com.angeloruggieridj.playlist-deck.stop",
      "Name": "Stop",
      "Tooltip": "Stop playback",
      "Icon": "icons/stop",
      "States": [{ "Image": "icons/stop", "TitleAlignment": "bottom" }]
    },
    {
      "UUID": "com.angeloruggieridj.playlist-deck.playitem",
      "Name": "Play Item",
      "Tooltip": "Play a specific playlist item by index",
      "Icon": "icons/playitem",
      "States": [{ "Image": "icons/playitem", "TitleAlignment": "bottom" }]
    }
  ]
}
